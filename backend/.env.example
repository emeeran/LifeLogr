# ── Application ──────────────────────────
APP_ENV=development
SECRET_KEY=change-me-before-production

# ── CORS ─────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Database ─────────────────────────────
# DATABASE_URL is auto-derived from DATA_DIR if not set.
# For explicit control:
# DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ── Data Directories ─────────────────────
# DATA_DIR and MEDIA_DIR auto-derive to platform defaults if not set.
# DATA_DIR defaults to ~/.local/share/lifelogr on Linux
# MEDIA_DIR defaults to {DATA_DIR}/media

# ── Connection Pool (for PostgreSQL only) ─
# SQLite uses pool_size=1 automatically
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ── Rate Limiting ────────────────────────
RATE_LIMIT=60/minute

# ── Upload Limits ────────────────────────
# MAX_MEDIA_SIZE_BYTES=26214400  # 25 MB

# ── Ollama / AI ──────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_TIMEOUT_SECONDS=300

# ── AI Feature Toggles ───────────────────
# AI_ENABLE_EMBEDDINGS=true
# AI_ENABLE_TAG_SUGGESTIONS=true
# AI_ENABLE_SENTIMENT=true
# AI_ENABLE_SUMMARIZATION=true
# AI_ENABLE_REFLECTION_PROMPTS=true
# AI_ENABLE_WRITER_BLOCK_HELPER=true

# ── OCR ──────────────────────────────────
# OCR_ENGINE=tesseract

# ── Whisper (voice-to-text) ──────────────
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
